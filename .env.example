# =============================================================================
# App (scripts/generate-index.ts — npm run generate / dev / build)
# =============================================================================
# 未設定時は下記が既定として使われます。
# Node は .env を自動読み込みしないため、使うときは export か direnv、または:
#   set -a && source .env && set +a && npm run build

METADATA_CACHE_TTL_HOURS=24
METADATA_CACHE_PATH=.cache/metadata-cache.json

# =============================================================================
# Terraform（ローカルで terraform apply するとき）
# =============================================================================
# Terraform は TF_VAR_<変数名> を変数として読み込みます（variables.tf と対応）。
# シェルに export したうえで terraform/ で terraform apply するか、
# terraform/terraform.tfvars.example を terraform.tfvars にコピーして使ってください。
#
# GitHub Actions の Secrets（GCP_PROJECT_ID 等）と同じ値を入れる想定です。
#
# 状態バケット（setup_gcp.sh では {project_id}-tfstate）。terraform init のみで使う。
#   terraform init -backend-config="bucket=${GCP_TF_STATE_BUCKET}"

GCP_TF_STATE_BUCKET=my-gcp-project-id-tfstate

TF_VAR_project_id=my-gcp-project-id
TF_VAR_github_repo=owner/repo
TF_VAR_cloudflare_api_token=
TF_VAR_cloudflare_zone_id=

# 任意（variables.tf の default と同じなら省略可）
# TF_VAR_region=us-central1
# TF_VAR_site_id=
# TF_VAR_custom_domain=card.tori-dev.com
