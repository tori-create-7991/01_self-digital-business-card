# scripts/generate-index.ts（npm run generate / dev / build で使用）
# 未設定時は下記が既定として使われます。
#
# このファイルを .env にコピーして編集する場合、Node は自動では読み込まないため、
# シェルで export するか、direnv などで読み込んでください。
# 例: set -a && source .env && set +a && npm run build

METADATA_CACHE_TTL_HOURS=24
METADATA_CACHE_PATH=.cache/metadata-cache.json
